{
  "name": "premium-astro-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro check && astro build",
    "preview": "astro preview --host 127.0.0.1",
    "test": "playwright test",
    "qa": "npm run build && playwright test",
    "screenshots": "playwright test tests/screenshot.spec.ts --update-snapshots",
    "optimize:images": "python3 scripts/optimize-images.py"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "astro": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@playwright/test": "latest"
  }
}
